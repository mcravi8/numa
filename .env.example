# ============================================================
# RESEARCH TERMINAL — environment configuration
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# All keys are optional — the app degrades gracefully without them.
# ============================================================

# Finnhub (free tier at https://finnhub.io) — powers richer news +
# sentiment and the peer list. Without it, the app falls back to
# yfinance news and a static sector-based peer map.
FINNHUB_API_KEY=

# FRED (free, https://fred.stlouisfed.org/docs/api/api_key.html — takes
# 30 seconds) — powers the Macro section: rates, labor, inflation, growth
# and the Fed-probability model. Without it, /macro still returns its
# structure but every FRED-sourced value comes back null.
FRED_API_KEY=your_fred_key_here

# Anthropic (https://console.anthropic.com) — powers the AI research
# synthesis section. Without it, the /synthesize endpoint returns an error.
ANTHROPIC_API_KEY=

# ---- Premium data providers (optional, used only in "premium" mode) ----
# Most premium modules still return realistic DEMO data (dark pool, gamma
# exposure, the options-flow overlay). Congressional trades are now LIVE from
# Quiver Quantitative — set QUIVER_API_KEY below to populate them.

# Quiver Quantitative (https://www.quiverquant.com/) — live STOCK Act
# congressional trading disclosures, shown in premium mode. Without it the
# Congress panel returns a "QUIVER_API_KEY not configured" error in premium.
QUIVER_API_KEY=

# Unusual Whales (~$50/mo, https://unusualwhales.com/pricing)
# Powers (demo data): options-flow overlay, dark pool, gamma exposure.
UNUSUAL_WHALES_API_KEY=

# Polygon.io ($29/mo Starter, https://polygon.io) — real-time quotes.
POLYGON_API_KEY=
